{
  "info": {
    "name": "Mini ERP + CRM Ops Portal",
    "description": "Core API endpoints: auth, customers, products, sales challans.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:4000" },
    { "key": "token", "value": "" },
    { "key": "customerId", "value": "" },
    { "key": "productId", "value": "" },
    { "key": "challanId", "value": "" }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Login (Admin)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/auth/login",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@erp.test\",\n  \"password\": \"password123\"\n}"
            }
          }
        },
        {
          "name": "Get current user",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/auth/me"
          }
        },
        {
          "name": "Create user (Admin only)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{baseUrl}}/auth/users",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"New Sales Rep\",\n  \"email\": \"newsales@erp.test\",\n  \"password\": \"password123\",\n  \"role\": \"SALES\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "Customers",
      "item": [
        {
          "name": "List customers",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/customers?search=&status=&page=1&pageSize=20"
          }
        },
        {
          "name": "Get customer by id",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/customers/{{customerId}}"
          }
        },
        {
          "name": "Create customer",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{baseUrl}}/customers",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Suresh Enterprises\",\n  \"mobile\": \"9123456780\",\n  \"customerType\": \"WHOLESALE\",\n  \"status\": \"LEAD\"\n}"
            }
          }
        },
        {
          "name": "Update customer",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{baseUrl}}/customers/{{customerId}}",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"ACTIVE\"\n}"
            }
          }
        },
        {
          "name": "Add follow-up note",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{baseUrl}}/customers/{{customerId}}/notes",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"note\": \"Called customer, will confirm order by Friday\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "Products",
      "item": [
        {
          "name": "List products",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/products?search=&lowStock=false&page=1&pageSize=20"
          }
        },
        {
          "name": "Get product by id",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/products/{{productId}}"
          }
        },
        {
          "name": "Create product",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{baseUrl}}/products",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"PVC Pipe 2 inch\",\n  \"sku\": \"SKU-002\",\n  \"category\": \"Plumbing\",\n  \"unitPrice\": 120.5,\n  \"currentStock\": 200,\n  \"minStockAlert\": 20,\n  \"location\": \"Warehouse A - Rack 7\"\n}"
            }
          }
        },
        {
          "name": "Update product",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{baseUrl}}/products/{{productId}}",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"unitPrice\": 125\n}"
            }
          }
        },
        {
          "name": "Add stock movement (IN)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{baseUrl}}/products/{{productId}}/stock-movements",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"quantity\": 100,\n  \"movementType\": \"IN\",\n  \"reason\": \"Purchase order received\"\n}"
            }
          }
        },
        {
          "name": "Add stock movement (OUT)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{baseUrl}}/products/{{productId}}/stock-movements",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"quantity\": 10,\n  \"movementType\": \"OUT\",\n  \"reason\": \"Damaged stock write-off\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "Sales Challans",
      "item": [
        {
          "name": "List challans",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/challans?status=&page=1&pageSize=20"
          }
        },
        {
          "name": "Get challan by id",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/challans/{{challanId}}"
          }
        },
        {
          "name": "Create challan (Draft)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{baseUrl}}/challans",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"customerId\": \"{{customerId}}\",\n  \"status\": \"Draft\",\n  \"items\": [\n    { \"productId\": \"{{productId}}\", \"quantity\": 5 }\n  ]\n}"
            }
          }
        },
        {
          "name": "Create + confirm challan directly",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{baseUrl}}/challans",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"customerId\": \"{{customerId}}\",\n  \"status\": \"Confirmed\",\n  \"items\": [\n    { \"productId\": \"{{productId}}\", \"quantity\": 5 }\n  ]\n}"
            }
          }
        },
        {
          "name": "Update draft challan items",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{baseUrl}}/challans/{{challanId}}/items",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"items\": [\n    { \"productId\": \"{{productId}}\", \"quantity\": 8 }\n  ]\n}"
            }
          }
        },
        {
          "name": "Confirm challan",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/challans/{{challanId}}/confirm"
          }
        },
        {
          "name": "Cancel challan",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/challans/{{challanId}}/cancel"
          }
        },
        {
          "name": "Download challan PDF",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/challans/{{challanId}}/pdf"
          }
        }
      ]
    }
  ]
}
